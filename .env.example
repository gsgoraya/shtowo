# Shopify (optional if .access_token exists)
SHOPIFY_STORE=peyufj-jz.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-01

# WooCommerce REST API (required for import)
WOO_URL=https://your-site.com
WOO_CONSUMER_KEY=ck_xxxxxxxx
WOO_CONSUMER_SECRET=cs_xxxxxxxx

# Optional: fixed User-Agent for Cloudflare/Kinsta allow rules
WOO_USER_AGENT=PeptologyMigration/1.0
# Docker container names for woo:fix-permalinks (optional)
# WOO_DOCKER_CONTAINER=my-wordpress-site-wordpress-1
# WOO_DOCKER_DB_CONTAINER=my-wordpress-site-db-1

# Paths (optional)
EXPORT_DIR=export
MAPPINGS_FILE=mappings/shopify-to-woo.json
